{
  "$schema": "https://lnav.org/schemas/correlation-v1.schema.json",
  "correlation_rules": {
    "brute_force_then_success": {
      "title": "Brute Force Followed by Successful Login",
      "description": "5+ failed logins followed by a success from the same IP within a time window",
      "severity": "high",
      "mitre_attack": ["T1110.001"],
      "tags": ["#brute-force"],
      "sequence": [
        {
          "id": "failed",
          "match": {
            "log_level": ["warning", "error"],
            "body_pattern": "(?i)(failed|invalid|denied).*(login|auth|password)",
            "entity_bind": {
              "ip-address": "$attacker_ip"
            }
          },
          "count": { "min": 5, "max": null },
          "window": "300s"
        },
        {
          "id": "success",
          "match": {
            "log_level": ["info"],
            "body_pattern": "(?i)(accepted|succeeded|authenticated)",
            "entity_bind": {
              "ip-address": "$attacker_ip"
            }
          },
          "count": { "min": 1 },
          "within_after": "600s"
        }
      ],
      "output": {
        "tag": "#brute-force-success",
        "comment_template": "Brute force: {$attacker_ip} had multiple failures then authenticated"
      }
    },
    "lateral_movement": {
      "title": "Lateral Movement Detected",
      "description": "Same credentials used from 3+ source IPs within one hour",
      "severity": "critical",
      "mitre_attack": ["T1021"],
      "tags": ["#lateral-movement"],
      "aggregation": {
        "group_by_entity": "username",
        "count_distinct_entity": "ip-address",
        "threshold": { "min": 3 },
        "window": "3600s"
      },
      "output": {
        "tag": "#lateral-movement",
        "comment_template": "User {$username} seen from {distinct_ip-address_count} IPs"
      }
    },
    "privilege_escalation": {
      "title": "Privilege Escalation Attempt",
      "description": "sudo/su usage patterns indicating privilege escalation",
      "severity": "high",
      "mitre_attack": ["T1548"],
      "tags": ["#priv-esc"],
      "sequence": [
        {
          "id": "su_attempt",
          "match": {
            "body_pattern": "(?i)(sudo|su)\\b.*\\b(root|admin)",
            "entity_bind": {
              "username": "$escalating_user"
            }
          },
          "count": { "min": 1 },
          "window": "60s"
        }
      ],
      "output": {
        "tag": "#priv-esc",
        "comment_template": "Privilege escalation: {$escalating_user} attempted sudo/su to root"
      }
    },
    "log_gap_tampering": {
      "title": "Log Gap / Tampering Detection",
      "description": "Unusually large time gaps in log files that may indicate tampering",
      "severity": "medium",
      "mitre_attack": ["T1070"],
      "tags": ["#log-gap"],
      "sequence": [
        {
          "id": "gap_indicator",
          "match": {
            "body_pattern": "(?i)(log.*rotated|log.*cleared|truncat|removed|delet).*log"
          },
          "count": { "min": 1 }
        }
      ],
      "output": {
        "tag": "#log-tampering",
        "comment_template": "Possible log tampering detected"
      }
    },
    "beaconing_detection": {
      "title": "C2 Beaconing Detection",
      "description": "Regular interval connections to the same external host suggesting C2 beaconing",
      "severity": "high",
      "mitre_attack": ["T1071"],
      "tags": ["#beaconing"],
      "aggregation": {
        "group_by_entity": "ip-address",
        "count_distinct_entity": "session-id",
        "threshold": { "min": 10 },
        "window": "3600s"
      },
      "output": {
        "tag": "#beaconing",
        "comment_template": "Potential beaconing: {$ip-address} with {distinct_session-id_count} connections"
      }
    },
    "data_exfiltration": {
      "title": "Large Data Transfer Detection",
      "description": "Unusually large outbound data transfers that may indicate exfiltration",
      "severity": "critical",
      "mitre_attack": ["T1041"],
      "tags": ["#exfiltration"],
      "sequence": [
        {
          "id": "large_transfer",
          "match": {
            "body_pattern": "(?i)(upload|sent|transfer|POST).*\\b(\\d{6,})\\s*(bytes|KB|MB|GB)",
            "entity_bind": {
              "ip-address": "$dest_ip"
            }
          },
          "count": { "min": 3 },
          "window": "1800s"
        }
      ],
      "output": {
        "tag": "#data-exfiltration",
        "comment_template": "Potential data exfiltration to {$dest_ip}: multiple large transfers"
      }
    }
  }
}
